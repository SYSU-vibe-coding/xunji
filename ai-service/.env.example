# Copy to .env and fill in to enable real model calls.
# Leave DASHSCOPE_API_KEY empty to keep the service running on the
# rule-based keyword baseline (useful for CI / offline dev).

# Internal business routes require this header:
# X-Service-Token: <AI_SERVICE_TOKEN>
# Generate a unique random value of at least 32 characters. Only isolated
# local development may leave it empty together with AI_LOCAL_DEV_MODE=true.
AI_SERVICE_TOKEN=
AI_LOCAL_DEV_MODE=false

# Public object-storage hosts may use exact names or *.suffix entries.
AI_ALLOWED_IMAGE_HOSTS=objects.example.edu
# Private IPs and single-label container names are rejected unless they match
# this separate exact-host list. Never put user-controlled hosts here.
AI_TRUSTED_PRIVATE_IMAGE_HOSTS=minio

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_TEXT_EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_VL_MODEL=qwen-vl-max
DASHSCOPE_TIMEOUT=8.0
