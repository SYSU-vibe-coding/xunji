# Copy to deploy/docker/.env before running compose if you want custom values.

MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=
DB_NAME=xunji
DB_USER=xunji
DB_PASSWORD=
DB_HOST=mysql
DB_PORT=3306

JWT_SECRET_KEY=
BOOTSTRAP_ADMIN_ENABLED=true
ADMIN_ACCOUNT=admin
ADMIN_PASSWORD=
ADMIN_PHONE=19900000000
DEBUG=true
SMS_DEBUG_ENABLED=true
# Comma-separated, explicit course-demo allowlist. Never use a wildcard.
SMS_DEMO_PHONES=13800138000,13900139000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:18080,http://localhost:18080,http://127.0.0.1:18081,http://localhost:18081

BACKEND_PORT=8080
AI_SERVICE_PORT=5000
AI_SERVICE_BASE_URL=http://ai-service:5000
# Generate a unique random value of at least 32 characters before compose up.
AI_SERVICE_TOKEN=
# Optional public object-storage hosts. Private hosts do not belong here.
AI_ALLOWED_IMAGE_HOSTS=
# Exact private host used only for backend-generated short-lived AI URLs.
AI_TRUSTED_PRIVATE_IMAGE_HOSTS=minio
USER_WEB_PORT=18080
ADMIN_WEB_PORT=18081

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=xunji-minio
MINIO_SECRET_KEY=
MINIO_BUCKET=xunji
# 仅用于浏览器动态签名；AI 使用 MINIO_ENDPOINT 生成的独立内部短签名。
# bucket 始终为私有；不要配置匿名 GetObject policy。
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000
MINIO_URL_EXPIRE_HOURS=168
MINIO_SENSITIVE_EXPIRE_HOURS=1
MINIO_AI_URL_EXPIRE_MINUTES=10
MINIO_MAX_IMAGE_PIXELS=25000000
MATCH_RECALCULATE_MAX_CANDIDATES=100
