# Backend
DB_HOST=localhost
DB_PORT=3306
DB_NAME=xunji
DB_USER=root
DB_PASSWORD=change_me

# Runtime security
JWT_SECRET_KEY=
BOOTSTRAP_ADMIN_ENABLED=false
ADMIN_ACCOUNT=admin
ADMIN_PASSWORD=
ADMIN_PHONE=19900000000
DEBUG=false
SMS_DEBUG_ENABLED=false
# Comma-separated course-demo phone allowlist; no wildcard is supported.
SMS_DEMO_PHONES=
CORS_ALLOWED_ORIGINS=http://127.0.0.1:18080,http://127.0.0.1:18081

# Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=xunji-minio
MINIO_SECRET_KEY=
MINIO_BUCKET=xunji
# 仅作为 presigned URL 的外部地址，bucket 必须保持私有。
MINIO_PUBLIC_BASE_URL=http://localhost:9000
MINIO_URL_EXPIRE_HOURS=168
MINIO_SENSITIVE_EXPIRE_HOURS=1
MINIO_AI_URL_EXPIRE_MINUTES=10
MINIO_MAX_IMAGE_PIXELS=25000000

# AI Service
AI_SERVICE_BASE_URL=http://localhost:5000
AI_SERVICE_TOKEN=
AI_ALLOWED_IMAGE_HOSTS=objects.example.edu
# Docker 网络填 minio；host 网络或本机服务可填 127.0.0.1。
AI_TRUSTED_PRIVATE_IMAGE_HOSTS=
MATCH_RECALCULATE_MAX_CANDIDATES=100
